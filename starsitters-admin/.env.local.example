# Copy to .env.local (gitignored). Use Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: CSV export route. Never commit real keys; set in deployment env only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
